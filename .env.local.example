# Memberstack
# Get your public key from app.memberstack.com > Settings > API Keys
NEXT_PUBLIC_MEMBERSTACK_PUBLIC_KEY=pk_your_public_key_here

# Optional: Your paid plan ID from Memberstack (used to verify paid membership)
# Found in app.memberstack.com > Plans > Your Plan > Plan ID
NEXT_PUBLIC_MEMBERSTACK_PAID_PLAN_ID=prc_your_plan_id_here

# YouTube Demo Video ID (the part after ?v= in the YouTube URL)
# Example: https://www.youtube.com/watch?v=dQw4w9WgXcQ → NEXT_PUBLIC_DEMO_VIDEO_ID=dQw4w9WgXcQ
NEXT_PUBLIC_DEMO_VIDEO_ID=your_youtube_video_id_here
